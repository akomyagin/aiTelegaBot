# aiTelegaBot — пример окружения. Скопируй в .env и заполни.
# .env в .gitignore — НИКОГДА не коммить реальные секреты.

# --- Telegram (Bot API) — обязательно ---
TELEGRAM_BOT_TOKEN=            # токен от @BotFather
TELEGRAM_CHAT_ID=             # твой chat_id (куда слать дайджест и от кого принимать команды)

# --- LLM (BYOK) — опционально; пусто => offline-суммаризатор ---
LLM_API_KEY=                  # ключ OpenAI-совместимого API
LLM_BASE_URL=                 # напр. https://api.openai.com/v1 или http://ollama:11434/v1
LLM_MODEL=                    # напр. gpt-4o-mini

# --- Планировщик ---
DIGEST_TIME=09:00             # ежедневный слот (HH:MM)
TZ=UTC                        # IANA-таймзона, напр. Europe/Moscow

# --- Состояние ---
DB_PATH=/data/state.db        # путь к SQLite (в контейнере — на volume)

# --- MTProto (Фаза 2, Этап 6) — заполнять только для чтения каналов через аккаунт ---
# ВНИМАНИЕ: используй ОТДЕЛЬНЫЙ вторичный Telegram-аккаунт, не основной личный.
# Session-файл = полный доступ к аккаунту; хранится на volume, вне git.
# Разовый интерактивный логин:  go run ./cmd/bot login
# MTPROTO_APP_ID=                 # app_id с my.telegram.org
# MTPROTO_APP_HASH=               # app_hash с my.telegram.org
# MTPROTO_SESSION_PATH=/data/session.encrypted
# MTPROTO_SESSION_KEY=            # hex-encoded 32-байтный AES-ключ; пусто => session без шифрования (dev)
#                                 # сгенерировать: openssl rand -hex 32
